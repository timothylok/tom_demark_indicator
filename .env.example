# Copy this file to .env and edit as needed.

# Comma-separated list of ticker symbols the TD engine will process by default.
STOCK_LIST=AAPL,TSLA,SPY,QQQ

# Discord webhook URL for daily signal notifications.
# Get this from: Discord channel > Edit Channel > Integrations > Webhooks > New Webhook > Copy Webhook URL
DISCORD_WEBHOOK_URL=
